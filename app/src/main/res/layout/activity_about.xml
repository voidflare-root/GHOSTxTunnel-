<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#ffffff">

    <include
        layout="@layout/toolbar_main"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:orientation="vertical"
            android:padding="10dip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- FIRST CARD: APP INFO -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="2.0dip"
                app:cardElevation="2.0dip"
                app:cardUseCompatPadding="true"
                app:cardBackgroundColor="#ffffff">

                <LinearLayout
                    android:orientation="vertical"
                    android:paddingTop="10dip"
                    android:paddingBottom="10dip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingRight="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dip"
                        android:layout_marginBottom="10dip"
                        android:minHeight="50dp"
                        android:paddingLeft="5dp">

                        <View
                            android:layout_width="15dp"
                            android:layout_height="wrap_content"/>

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:src="@drawable/ghost_logo_circle"/>

                        <View
                            android:layout_width="15dp"
                            android:layout_height="wrap_content"/>

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:textAppearance="@style/TextAppearance.AppCompat.Title"
                                android:textStyle="bold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#000000"
                                android:text="@string/app_name"/>

                            <TextView
                                android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                                android:textColor="#000000"
                                android:text=""
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingLeft="5dp"
                        android:paddingRight="5dp"
                        android:clickable="true"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="50dp">

                        <View
                            android:layout_width="20dp"
                            android:layout_height="wrap_content"/>

                        <ImageView
                            android:src="@drawable/ic_info"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            app:tint="#000000"/>

                        <View
                            android:layout_width="20dp"
                            android:layout_height="wrap_content"/>

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#000000"
                                android:text="Version"/>

                            <TextView
                                android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                                android:textColor="#000000"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:id="@+id/appVersion"/>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- SECOND CARD: SOCIAL MEDIA -->
            <androidx.cardview.widget.CardView
                android:visibility="visible"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="2.0dip"
                app:cardElevation="2.0dip"
                app:cardUseCompatPadding="true">
                <LinearLayout
                    android:orientation="vertical"
                    android:paddingTop="10.0dip"
                    android:paddingBottom="10.0dip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15.0dip"
                        android:layout_marginBottom="10.0dip"
                        android:text="Social Media's"/>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="?selectableItemBackground"
                        android:paddingLeft="5.0dip"
                        android:paddingRight="5.0dip"
                        android:clickable="true"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="50.0dip">
                        <View
                            android:layout_width="20.0dip"
                            android:layout_height="wrap_content"/>
                        <ImageButton
                            android:background="@android:color/transparent"
                            android:layout_width="40.0dip"
                            android:layout_height="40.0dip"
                            app:tint="#ff999999"
                            app:srcCompat="@drawable/ic_person"/>
                        <View
                            android:layout_width="20.0dip"
                            android:layout_height="wrap_content"/>
                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Telegram"/>
                            <TextView
                                android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                                android:autoLink="web"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="https://t.me/HexGHOSTxTunnel"/>
                        </LinearLayout>
                    </LinearLayout>
                    
                    <!-- Empty Placeholder Item -->
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="?selectableItemBackground"
                        android:paddingLeft="5.0dip"
                        android:paddingRight="5.0dip"
                        android:clickable="true"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="50.0dip">
                        <View
                            android:layout_width="20.0dip"
                            android:layout_height="wrap_content"/>
                        <ImageButton
                            android:background="@android:color/transparent"
                            android:layout_width="40.0dip"
                            android:layout_height="40.0dip"
                            app:tint="#ff999999"
                            app:srcCompat="@drawable/ic_person"/>
                        <View
                            android:layout_width="20.0dip"
                            android:layout_height="wrap_content"/>
                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""/>
                            <TextView
                                android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                                android:autoLink="web"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- THIRD CARD: DEVELOPER / CREDITS (FIXED) -->
            <androidx.cardview.widget.CardView
                android:visibility="visible"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="2.0dip"
                app:cardElevation="2.0dip"
                app:cardUseCompatPadding="true">
                <LinearLayout
                    android:orientation="vertical"
                    android:paddingTop="10.0dip"
                    android:paddingBottom="10.0dip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15.0dip"
                        android:layout_marginBottom="10.0dip"
                        android:text="Credits"/>

                    <!-- PIYUSH / DEVELOPER SECTION -->
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="?selectableItemBackground"
                        android:paddingLeft="5.0dip"
                        android:paddingRight="5.0dip"
                        android:clickable="true"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="50.0dip">
                        <View
                            android:layout_width="20.0dip"
                            android:layout_height="wrap_content"/>
                        <ImageButton
                            android:background="@android:color/transparent"
                            android:layout_width="40.0dip"
                            android:layout_height="40.0dip"
                            app:srcCompat="@drawable/ic_person"
                            app:tint="#ff999999" />
                        <View
                            android:layout_width="20.0dip"
                            android:layout_height="wrap_content"/>
                        
                        <!-- Fixed Layout ID and Text Structure -->
                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="match_parent"
                            android:id="@+id/tgDev"
                            android:layout_height="wrap_content">

                            <!-- NAME HERE -->
                            <TextView
                                android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PIYUSH"
                                android:textStyle="bold"
                                android:textColor="#000000"
                                tools:ignore="HardcodedText" />

                            <!-- CAPTION HERE -->
                            <TextView
                                android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Developer"
                                tools:ignore="HardcodedText" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- TELEGRAM CHANNEL SECTION -->
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="?selectableItemBackground"
                        android:paddingLeft="5.0dip"
                        android:paddingRight="5.0dip"
                        android:clickable="true"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="50.0dip">
                        <View
                            android:layout_width="20.0dip"
                            android:layout_height="wrap_content"/>
                        <ImageButton
                            android:background="@android:color/transparent"
                            android:layout_width="40.0dip"
                            android:layout_height="40.0dip"
                            app:srcCompat="@drawable/ic_person"
                            app:tint="#ff999999" />
                        <View
                            android:layout_width="20.0dip"
                            android:layout_height="wrap_content"/>

                        <!-- NO CAMBIAR ESTOS CREDITOS -->
                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="match_parent"
                            android:id="@+id/tgChannel"
                            android:layout_height="wrap_content">
                            <TextView
                                android:textAppearance="@style/TextAppearance.AppCompat.Subhead"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Telegram"
                                tools:ignore="HardcodedText" />
                            <TextView
                                android:textAppearance="@style/TextAppearance.AppCompat.Caption"
                                android:autoLink="web"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Join Telegram Channel"
                                tools:ignore="HardcodedText" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

    </ScrollView>
</LinearLayout>
