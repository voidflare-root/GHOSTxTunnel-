<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:orientation="vertical">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary"
        app:title="Hotshare"
        app:titleTextColor="#FFFFFF" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="15dp">

            <!-- Step Progress Indicator -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="10dp">

                <TextView
                    android:id="@+id/step1_circle"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/circle_active"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <View
                    android:id="@+id/line1"
                    android:layout_width="80dp"
                    android:layout_height="2dp"
                    android:background="#444444" />

                <TextView
                    android:id="@+id/step2_circle"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/circle_inactive"
                    android:gravity="center"
                    android:text="2"
                    android:textColor="#888888"
                    android:textStyle="bold" />

                <View
                    android:id="@+id/line2"
                    android:layout_width="80dp"
                    android:layout_height="2dp"
                    android:background="#444444" />

                <TextView
                    android:id="@+id/step3_circle"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/circle_inactive"
                    android:gravity="center"
                    android:text="3"
                    android:textColor="#888888"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Status Info List -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="15dp">

                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SSID" android:textColor="#CCCCCC" android:textStyle="bold" />
                    <TextView android:id="@+id/txtSSID" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="-" android:textColor="#FFFFFF" />
                </RelativeLayout>

                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Password" android:textColor="#CCCCCC" android:textStyle="bold" />
                    <TextView android:id="@+id/txtPass" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="-" android:textColor="#FFFFFF" />
                </RelativeLayout>

                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Proxy IP" android:textColor="#CCCCCC" android:textStyle="bold" />
                    <TextView android:id="@+id/txtIP" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="-" android:textColor="#FFFFFF" />
                </RelativeLayout>

                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Proxy Port (HTTP)" android:textColor="#CCCCCC" android:textStyle="bold" />
                    <TextView android:id="@+id/txtPort" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="-" android:textColor="#FFFFFF" />
                </RelativeLayout>

                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HTTP Usage" android:textColor="#CCCCCC" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="-" android:textColor="#FFFFFF" />
                </RelativeLayout>
            </LinearLayout>

            <CheckBox
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Auto turn off Hotshare if VPN disconnected"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:buttonTint="?attr/colorPrimary"/>

            <!-- STEP 1 CARD -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="15dp" android:text="Step 1" android:textColor="#FFFFFF" android:textStyle="bold" />
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="#212121"
                app:cardCornerRadius="8dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Start Wi-Fi hotspot (recommended) or Repeater" android:textColor="#AAAAAA" android:textSize="12sp" android:textStyle="bold" />
                    
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp">
                        <Button android:id="@+id/btnHotspot" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_toStartOf="@+id/icon_settings" android:backgroundTint="?attr/colorPrimary" android:text="Start Wi-Fi Hotspot" android:textColor="#FFFFFF" android:textAllCaps="false" />
                        <ImageView android:id="@+id/icon_settings" android:layout_width="24dp" android:layout_height="24dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:layout_marginStart="10dp" android:src="@android:drawable/ic_menu_preferences" app:tint="#888888" />
                    </RelativeLayout>

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp">
                        <Button android:id="@+id/btnRepeater" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_toStartOf="@+id/icon_info" android:backgroundTint="?attr/colorPrimary" android:text="Start Repeater" android:textColor="#FFFFFF" android:textAllCaps="false" />
                        <ImageView android:id="@+id/icon_info" android:layout_width="24dp" android:layout_height="24dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:layout_marginStart="10dp" android:src="@android:drawable/ic_dialog_info" app:tint="#888888" />
                    </RelativeLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- STEP 2 CARD -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="15dp" android:text="Step 2" android:textColor="#FFFFFF" android:textStyle="bold" />
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="#212121"
                app:cardCornerRadius="8dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                        <CheckBox android:checked="true" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HTTP" android:textColor="#FFFFFF" android:buttonTint="?attr/colorPrimary"/>
                        <CheckBox android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="15dp" android:text="SOCKS" android:textColor="#FFFFFF" android:buttonTint="?attr/colorPrimary"/>
                    </LinearLayout>
                    <Button android:id="@+id/btnStartHotshare" android:layout_width="match_parent" android:layout_height="60dp" android:layout_marginTop="12dp" android:backgroundTint="?attr/colorPrimary" android:text="START HOTSHARE" android:textColor="#FFFFFF" android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- STEP 3 CARD -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="15dp" android:text="Step 3" android:textColor="#FFFFFF" android:textStyle="bold" />
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="30dp"
                app:cardBackgroundColor="#212121"
                app:cardCornerRadius="8dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="15dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="1. Connect another device to the WiFi network using the SSID/Password." android:textColor="#BBBBBB" android:textSize="13sp" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="2. Set up proxy on the connected device." android:textColor="#BBBBBB" android:textSize="13sp" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="(Search online on how to set up proxy on your device or check this guide)" android:textColor="#777777" android:textSize="12sp" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="You do not need to install this app and run Hotshare in the other device" android:textColor="#BBBBBB" android:textSize="13sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>